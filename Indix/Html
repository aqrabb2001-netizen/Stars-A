let mode=1, selA=null, selB=null, selM=null;
let results={center:[],A:[],B:[],rotCenter:[],rotStar:[]};
let sortState={}, resTab='center', rotTab='center', computed=false;

document.addEventListener('DOMContentLoaded',()=>{
  buildDD('ddA'); buildDD('ddB'); buildDD('ddM');
  document.addEventListener('click', closeAllDD);
  loadInputs(); // تحميل القيم المحفوظة
});

function buildDD(id){
  const list=document.getElementById(id+'_list');
  list.innerHTML=STARS.map((s,i)=>
    `<div class="dd-item" onclick="selectStar('${id}',${i})">
      <span>${s.n}</span>${s.c?'<span class="dd-tag">ثابتة</span>':''}
    </div>`).join('');
}
function openDD(id){closeAllDD();document.getElementById(id).classList.add('open');setTimeout(()=>document.getElementById(id+'_search').focus(),50);event.stopPropagation()}
function closeAllDD(){document.querySelectorAll('.dropdown').forEach(d=>d.classList.remove('open'))}
function filterDD(id){
  const q=document.getElementById(id+'_search').value.trim().toLowerCase();
  document.querySelectorAll('#'+id+'_list .dd-item').forEach(el=>el.style.display=el.textContent.toLowerCase().includes(q)?'':'none');
}
function selectStar(ddId,idx){
  const s=STARS[idx];
  if(ddId==='ddA'){selA=s;document.getElementById('starA_display').value=s.n}
  if(ddId==='ddB'){selB=s;document.getElementById('starB_display').value=s.n}
  if(ddId==='ddM'){selM=s;document.getElementById('starM_display').value=s.n}
  closeAllDD();
  saveInputs(); // حفظ بعد كل اختيار
}

// -------------------- حفظ و تحميل المدخلات --------------------
function saveInputs(){
  const data={
    mode: mode,
    starA: selA? selA.n : '',
    starB: selB? selB.n : '',
    starM: selM? selM.n : '',
    distAB: document.getElementById('distAB').value,
    bearAB: document.getElementById('bearAB').value,
    scaleM: document.getElementById('scaleM').value,
    rotM: document.getElementById('rotM').value,
    manScale: document.getElementById('manScale').value,
    manRot: document.getElementById('manRot').value
  };
  localStorage.setItem('starNav', JSON.stringify(data));
}
function loadInputs(){
  const saved = localStorage.getItem('starNav');
  if(!saved) return;
  try{
    const data = JSON.parse(saved);
    if(data.mode!==undefined){
      mode = data.mode;
      document.querySelectorAll('.mode-tab').forEach((el,i)=>{
        if((mode===1 && i===0) || (mode===2 && i===1)) el.classList.add('active');
        else el.classList.remove('active');
      });
      document.getElementById('mode1').style.display = mode===1?'':'none';
      document.getElementById('mode2').style.display = mode===2?'':'none';
    }
    if(data.starA){
      const s = STARS.find(st=>st.n===data.starA);
      if(s){selA=s; document.getElementById('starA_display').value=s.n;}
    }
    if(data.starB){
      const s = STARS.find(st=>st.n===data.starB);
      if(s){selB=s; document.getElementById('starB_display').value=s.n;}
    }
    if(data.starM){
      const s = STARS.find(st=>st.n===data.starM);
      if(s){selM=s; document.getElementById('starM_display').value=s.n;}
    }
    if(data.distAB) document.getElementById('distAB').value = data.distAB;
    if(data.bearAB) document.getElementById('bearAB').value = data.bearAB;
    if(data.scaleM) document.getElementById('scaleM').value = data.scaleM;
    if(data.rotM) document.getElementById('rotM').value = data.rotM;
    if(data.manScale) document.getElementById('manScale').value = data.manScale;
    if(data.manRot) document.getElementById('manRot').value = data.manRot;
  }catch(e){}
}

// -------------------- الدوال الرياضية --------------------
function dist(ax,ay,bx,by){return Math.sqrt((bx-ax)**2+(by-ay)**2)}
function bearing(ax,ay,bx,by){
  let dx = bx - ax;
  let dy = by - ay;
  let angle = Math.atan2(dy, dx) * 180 / Math.PI;   // الزاوية من الشرق
  return (90 - angle + 360) % 360;                   // تحويل إلى زاوية من الشمال
}
function transform(sx,sy,scale,rotDeg){
  const r = rotDeg * Math.PI/180;
  const tx = sx * scale;
  const ty = sy * scale;
  return {
    x: tx * Math.cos(r) - ty * Math.sin(r),
    y: tx * Math.sin(r) + ty * Math.cos(r)
  };
}
function calcSR(sA,sB,realDist,realBear){
  const d = dist(sA.x, sA.y, sB.x, sB.y);
  if(d===0) return null;
  const sb = bearing(sA.x, sA.y, sB.x, sB.y);
  return {
    scale: realDist / d,
    rot: (realBear - sb + 360) % 360,
    starDist: d,
    starBear: sb
  };
}

// -------------------- الحساب الرئيسي --------------------
function calculate(){
  hideErr();
  let scale, rot;
  if(mode===1){
    if(!selA||!selB) return showErr('اختر نجمتين أولاً');
    const d = parseFloat(document.getElementById('distAB').value);
    const b = parseFloat(document.getElementById('bearAB').value);
    if(isNaN(d)||isNaN(b)) return showErr('أدخل المسافة والبوصلة');
    const sr = calcSR(selA,selB,d,b);
    if(!sr) return showErr('النجمان متطابقان');
    scale = sr.scale; rot = sr.rot;
    document.getElementById('sumScale').textContent = scale.toFixed(6);
    document.getElementById('sumRot').textContent = rot.toFixed(2)+'°';
    document.getElementById('sumDistStar').textContent = sr.starDist.toFixed(4);
    document.getElementById('sumStarBear').textContent = sr.starBear.toFixed(2)+'°';
    document.getElementById('abSummary').style.display = 'block';
    const tA = transform(selA.x, selA.y, scale, rot);
    const tB = transform(selB.x, selB.y, scale, rot);
    results.center = STARS.map(s=>{
      const t = transform(s.x, s.y, scale, rot);
      return {n:s.n, c:s.c, dist: dist(0,0,t.x,t.y), bear: bearing(0,0,t.x,t.y)};
    });
    results.A = STARS.map(s=>{
      const t = transform(s.x, s.y, scale, rot);
      return {n:s.n, c:s.c, dist: dist(tA.x, tA.y, t.x, t.y), bear: bearing(tA.x, tA.y, t.x, t.y)};
    });
    results.B = STARS.map(s=>{
      const t = transform(s.x, s.y, scale, rot);
      return {n:s.n, c:s.c, dist: dist(tB.x, tB.y, t.x, t.y), bear: bearing(tB.x, tB.y, t.x, t.y)};
    });
  } else {
    if(!selM) return showErr('اختر نجماً معروفاً');
    scale = parseFloat(document.getElementById('scaleM').value);
    rot = parseFloat(document.getElementById('rotM').value);
    if(isNaN(scale)||isNaN(rot)) return showErr('أدخل التحجيم والإدارة');
    results.center = STARS.map(s=>{
      const t = transform(s.x, s.y, scale, rot);
      return {n:s.n, c:s.c, dist: dist(0,0,t.x,t.y), bear: bearing(0,0,t.x,t.y)};
    });
    const tM = transform(selM.x, selM.y, scale, rot);
    results.A = STARS.map(s=>{
      const t = transform(s.x, s.y, scale, rot);
      return {n:s.n, c:s.c, dist: dist(tM.x, tM.y, t.x, t.y), bear: bearing(tM.x, tM.y, t.x, t.y)};
    });
    results.B = results.A; // نفس الشيء
    document.getElementById('abSummary').style.display = 'none';
  }
  computed = true;
  calcRotated(); // تحديث صفحة المدار تلقائياً
  showPage('results');
  setResTab('center', document.querySelector('#page-results .res-tab'));
  saveInputs(); // حفظ بعد الحساب
}

function calcRotated(){
  const scale = parseFloat(document.getElementById('manScale').value);
  const rot = parseFloat(document.getElementById('manRot').value);
  if(isNaN(scale)||isNaN(rot)) return;
  results.rotCenter = STARS.map(s=>{
    const t = transform(s.x, s.y, scale, rot);
    return {n:s.n, c:s.c, dist: dist(0,0,t.x,t.y), bear: bearing(0,0,t.x,t.y)};
  });
  // النجم المرجعي: نختار آخر نجم تم اختياره في وضع الإدخال
  const ref = selM || selA || STARS[0];
  const tRef = transform(ref.x, ref.y, scale, rot);
  results.rotStar = STARS.map(s=>{
    const t = transform(s.x, s.y, scale, rot);
    return {n:s.n, c:s.c, dist: dist(tRef.x, tRef.y, t.x, t.y), bear: bearing(tRef.x, tRef.y, t.x, t.y)};
  });
  renderList('rot', rotTab==='center'?results.rotCenter:results.rotStar);
  saveInputs(); // حفظ القيم اليدوية
}

// -------------------- عرض النتائج --------------------
function getResData(){
  if(resTab==='center') return results.center;
  if(resTab==='A') return results.A;
  return results.B;
}
function renderList(key, data){
  const sid = key==='res'?'searchRes':'searchRot';
  const q = (document.getElementById(sid)||{value:''}).value.trim().toLowerCase();
  const filtered = data.filter(r=>r.n.toLowerCase().includes(q));
  const cnt = document.getElementById('count'+(key==='res'?'Res':'Rot'));
  if(cnt) cnt.textContent = filtered.length+' نجم';
  const body = document.getElementById('tbody'+(key==='res'?'Res':'Rot'));
  if(!filtered.length){body.innerHTML='<div class="no-data">لا توجد نتائج</div>';return}
  body.innerHTML = filtered.map(r=>`
    <div class="res-row${r.c?' corner':''}">
      <div class="rname${r.c?' corner':''}">${r.c?'<span class="rtag">◈</span>':''}${r.n}</div>
      <div class="rdist">${r.dist.toFixed(3)}</div>
      <div class="rbear">${r.bear.toFixed(1)}°</div>
    </div>`).join('');
}
function filterTable(key){
  renderList(key, key==='res'?getResData():(rotTab==='center'?results.rotCenter:results.rotStar));
}
function sortTable(key,field){
  const sk = key+'_'+field;
  sortState[sk] = sortState[sk]==='asc'?'desc':'asc';
  const asc = sortState[sk]==='asc';
  const data = key==='res'?getResData():(rotTab==='center'?results.rotCenter:results.rotStar);
  data.sort((a,b)=>{
    if(field==='n') return asc? a.n.localeCompare(b.n) : b.n.localeCompare(a.n);
    else return asc? a[field]-b[field] : b[field]-a[field];
  });
  renderList(key, data);
}

// -------------------- واجهة المستخدم --------------------
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  ['input','results','rotated'].forEach((p,i)=>{if(p===id)document.querySelectorAll('.nav-btn')[i].classList.add('active')});
}
function setMode(m,el){
  mode=m;
  document.querySelectorAll('.mode-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('mode1').style.display = m===1?'':'none';
  document.getElementById('mode2').style.display = m===2?'':'none';
  saveInputs();
}
function setResTab(tab,el){
  resTab=tab;
  document.querySelectorAll('#page-results .res-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  if(computed) renderList('res',getResData());
}
function setRotTab(tab,el){
  rotTab=tab;
  document.querySelectorAll('#page-rotated .res-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  renderList('rot', tab==='center'?results.rotCenter:results.rotStar);
}
function showErr(msg){const e=document.getElementById('errorMsg');e.textContent=msg;e.style.display='block'}
function hideErr(){document.getElementById('errorMsg').style.display='none'}
</script>
