<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#080c17">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>مستكشف النجوم ✦ (نسخة Excel)</title>
<style>
:root{
  --bg:#06090f;--bg2:#0d1526;--bg3:#111e35;--bg4:#162040;
  --gold:#c9973a;--gold2:#f5c842;
  --cyan:#3ecfb8;--red:#e05555;
  --text:#e8dfc8;--text2:#7a6a50;
  --border:#1e2e4a;--border2:#2a3e60;
  --r:12px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',Tahoma,Arial,sans-serif;font-size:14px;display:flex;flex-direction:column}

/* NAV */
.nav{display:flex;background:var(--bg2);border-bottom:2px solid var(--border2);flex-shrink:0}
.nav-btn{flex:1;padding:12px 4px 10px;font-size:10px;font-weight:600;color:var(--text2);border:none;background:none;cursor:pointer;border-bottom:3px solid transparent;transition:.2s;text-align:center;line-height:1.4}
.nav-btn .ico{display:block;font-size:18px;margin-bottom:2px}
.nav-btn.active{color:var(--gold2);border-bottom-color:var(--gold)}

/* PAGES */
.page{display:none;flex:1;overflow-y:auto;padding:12px;flex-direction:column}
.page.active{display:flex}

/* CARD */
.card{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--r);padding:14px;margin-bottom:12px;flex-shrink:0}
.card-title{font-size:13px;color:var(--gold2);margin-bottom:12px;display:flex;align-items:center;gap:7px;font-weight:600}

/* FORM */
label{display:block;font-size:11px;color:var(--text2);margin-bottom:5px;font-weight:600}
input{width:100%;padding:10px 12px;background:var(--bg3);border:1.5px solid var(--border);color:var(--text);border-radius:8px;font-size:14px;outline:none;transition:.2s}
input:focus{border-color:var(--gold);background:var(--bg4)}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fg{margin-bottom:12px}

/* DROPDOWN */
.sw{position:relative}
.star-input{cursor:pointer;padding-left:32px}
.dd-arrow{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--gold);font-size:12px;pointer-events:none}
.dropdown{position:absolute;top:calc(100% + 4px);right:0;left:0;background:var(--bg3);border:1.5px solid var(--gold);border-radius:10px;max-height:220px;overflow:hidden;z-index:500;display:none;box-shadow:0 8px 30px rgba(0,0,0,.6);flex-direction:column}
.dropdown.open{display:flex}
.dd-search-wrap{padding:8px;border-bottom:1px solid var(--border);flex-shrink:0}
.dd-search-wrap input{border-color:var(--border2);font-size:13px;padding:7px 10px}
.dd-list{overflow-y:auto;flex:1}
.dd-item{padding:9px 14px;cursor:pointer;font-size:13px;border-bottom:1px solid rgba(30,46,74,.4);display:flex;justify-content:space-between;align-items:center}
.dd-item:hover{background:rgba(201,151,58,.15);color:var(--gold2)}
.dd-tag{font-size:10px;color:var(--cyan);background:rgba(62,207,184,.1);padding:2px 6px;border-radius:10px}

/* MODE TABS */
.mode-tabs{display:flex;gap:6px;margin-bottom:14px}
.mode-tab{flex:1;padding:9px;text-align:center;border-radius:8px;border:1.5px solid var(--border);color:var(--text2);font-size:12px;cursor:pointer;transition:.2s;font-weight:600}
.mode-tab.active{background:rgba(201,151,58,.15);border-color:var(--gold);color:var(--gold2)}

/* BTN */
.btn{width:100%;padding:13px;background:linear-gradient(135deg,#c9832a,#8a5515);color:#fff;border:none;border-radius:10px;font-size:15px;cursor:pointer;font-weight:700;letter-spacing:1px;transition:.15s;box-shadow:0 4px 15px rgba(180,100,20,.3)}
.btn:active{opacity:.85;transform:scale(.98)}

/* SUMMARY */
.sum-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.sum-box{background:var(--bg3);border:1px solid var(--border2);border-radius:10px;padding:10px;text-align:center}
.sum-label{font-size:10px;color:var(--text2);margin-bottom:4px}
.sum-val{font-size:16px;color:var(--gold2);font-weight:700}
.sum-val.c{color:var(--cyan)}

/* RESULT TABS — 3 tabs */
.res-tabs{display:flex;gap:0;margin-bottom:0;flex-shrink:0;background:var(--bg3);border-radius:10px 10px 0 0;overflow:hidden;border:1px solid var(--border2);border-bottom:none}
.res-tab{flex:1;padding:10px 6px;text-align:center;color:var(--text2);font-size:12px;cursor:pointer;transition:.2s;font-weight:600;border-left:1px solid var(--border2)}
.res-tab:last-child{border-left:none}
.res-tab.active{background:var(--bg4);color:var(--gold2);border-bottom:2px solid var(--gold)}

/* TABLE CONTAINER */
.tbl-container{background:var(--bg3);border:1px solid var(--border2);border-radius:0 0 10px 10px;display:flex;flex-direction:column;flex:1;min-height:0}
.count-bar{display:flex;justify-content:space-between;align-items:center;padding:6px 12px;font-size:11px;color:var(--text2);border-bottom:1px solid var(--border);flex-shrink:0}
.res-header{display:grid;grid-template-columns:1fr 85px 85px;padding:7px 12px;font-size:11px;color:var(--gold);border-bottom:1px solid var(--border2);font-weight:600;cursor:pointer;flex-shrink:0}
.res-header span:not(:first-child){text-align:center}
.res-list{overflow-y:auto;flex:1}
.res-row{display:grid;grid-template-columns:1fr 85px 85px;padding:10px 12px;border-bottom:1px solid rgba(30,46,74,.5);align-items:center;transition:.15s}
.res-row:hover{background:rgba(201,151,58,.07)}
.res-row.corner{background:rgba(62,207,184,.04)}
.rname{font-size:13px;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.rname.corner{color:var(--cyan)}
.rtag{display:inline-block;font-size:9px;color:var(--cyan);background:rgba(62,207,184,.1);padding:1px 5px;border-radius:8px;margin-left:4px;vertical-align:middle}
.rdist{text-align:center;font-size:14px;color:var(--gold2);font-weight:700}
.rbear{text-align:center;font-size:14px;color:var(--cyan);font-weight:600}
.no-data{text-align:center;padding:30px;color:var(--text2);font-size:13px}

/* SEARCH */
.sbar{position:relative;flex-shrink:0;padding:8px 12px;background:var(--bg3);border-bottom:1px solid var(--border)}
.sbar input{padding-right:34px;background:var(--bg4);border-color:var(--border2);font-size:13px}
.sbar::before{content:'🔍';position:absolute;right:22px;top:50%;transform:translateY(-50%);font-size:13px;pointer-events:none}

/* ERR */
.err{color:var(--red);font-size:12px;padding:9px 12px;background:rgba(224,85,85,.1);border-radius:8px;margin-top:10px;border:1px solid rgba(224,85,85,.2)}
.tip{text-align:center;padding:16px;color:var(--text2);font-size:12px;line-height:1.6}

/* ROTATED manual settings */
.rot-settings{display:flex;gap:8px;align-items:flex-end;flex-shrink:0;margin-bottom:12px}
.rot-settings .fg{flex:1;margin-bottom:0}
.rot-settings .btn{width:auto;padding:10px 18px;font-size:13px;flex-shrink:0}

::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}
</style>
</head>
<body>

<!-- NAV -->
<div class="nav">
  <button class="nav-btn active" onclick="showPage('input')">
    <span class="ico">⚙️</span>إدخال
  </button>
  <button class="nav-btn" onclick="showPage('results')">
    <span class="ico">📊</span>النتائج
  </button>
  <button class="nav-btn" onclick="showPage('rotated')">
    <span class="ico">🔃</span>مدار
  </button>
</div>

<!-- ══ PAGE INPUT ══ -->
<div class="page active" id="page-input">
  <div class="card">
    <div class="card-title">✦ وضع الإدخال</div>
    <div class="mode-tabs">
      <div class="mode-tab active" onclick="setMode(1,this)">نجمان معروفان</div>
      <div class="mode-tab" onclick="setMode(2,this)">نجم + تحجيم + إدارة</div>
    </div>

    <div id="mode1">
      <div class="fg">
        <label>نجم أ</label>
        <div class="sw">
          <input class="star-input" id="starA_display" placeholder="اختر أو ابحث…" readonly onclick="openDD('ddA')">
          <span class="dd-arrow">▼</span>
          <div class="dropdown" id="ddA">
            <div class="dd-search-wrap"><input id="ddA_search" placeholder="ابحث…" oninput="filterDD('ddA')" onclick="event.stopPropagation()"></div>
            <div class="dd-list" id="ddA_list"></div>
          </div>
        </div>
      </div>
      <div class="fg">
        <label>نجم ب</label>
        <div class="sw">
          <input class="star-input" id="starB_display" placeholder="اختر أو ابحث…" readonly onclick="openDD('ddB')">
          <span class="dd-arrow">▼</span>
          <div class="dropdown" id="ddB">
            <div class="dd-search-wrap"><input id="ddB_search" placeholder="ابحث…" oninput="filterDD('ddB')" onclick="event.stopPropagation()"></div>
            <div class="dd-list" id="ddB_list"></div>
          </div>
        </div>
      </div>
      <div class="row2">
        <div class="fg">
          <label>المسافة بين أ-ب</label>
          <input type="number" id="distAB" placeholder="مثال: 6.7" step="0.01">
        </div>
        <div class="fg">
          <label>البوصلة أ ← ب (°)</label>
          <input type="number" id="bearAB" placeholder="مثال: 97" step="0.1">
        </div>
      </div>
    </div>

    <div id="mode2" style="display:none">
      <div class="fg">
        <label>النجم المعروف</label>
        <div class="sw">
          <input class="star-input" id="starM_display" placeholder="اختر أو ابحث…" readonly onclick="openDD('ddM')">
          <span class="dd-arrow">▼</span>
          <div class="dropdown" id="ddM">
            <div class="dd-search-wrap"><input id="ddM_search" placeholder="ابحث…" oninput="filterDD('ddM')" onclick="event.stopPropagation()"></div>
            <div class="dd-list" id="ddM_list"></div>
          </div>
        </div>
      </div>
      <div class="row2">
        <div class="fg"><label>التحجيم</label><input type="number" id="scaleM" placeholder="0.095" step="0.001"></div>
        <div class="fg"><label>الإدارة (°)</label><input type="number" id="rotM" placeholder="51" step="0.1"></div>
      </div>
    </div>

    <div id="errorMsg" class="err" style="display:none"></div>
    <button class="btn" onclick="calculate()">✦ احسب النتائج</button>
  </div>

  <div class="card" id="abSummary" style="display:none">
    <div class="card-title">📊 ملخص الحساب</div>
    <div class="sum-grid">
      <div class="sum-box"><div class="sum-label">التحجيم المحسوب</div><div class="sum-val" id="sumScale">—</div></div>
      <div class="sum-box"><div class="sum-label">الإدارة المحسوبة</div><div class="sum-val c" id="sumRot">—</div></div>
      <div class="sum-box"><div class="sum-label">مسافة أ-ب (نجوم)</div><div class="sum-val" id="sumDistStar">—</div></div>
      <div class="sum-box"><div class="sum-label">بوصلة أ-ب (نجوم)</div><div class="sum-val c" id="sumStarBear">—</div></div>
    </div>
  </div>

  <div class="tip">اضغط "احسب" ثم انتقل لـ "النتائج" من الشريط العلوي</div>
</div>

<!-- ══ PAGE RESULTS ══ -->
<div class="page" id="page-results">
  <!-- 3 tabs: المركز / أ / ب -->
  <div class="res-tabs">
    <div class="res-tab active" onclick="setResTab('center',this)">🎯 المركز</div>
    <div class="res-tab" onclick="setResTab('A',this)">📍 من أ</div>
    <div class="res-tab" onclick="setResTab('B',this)">📍 من ب</div>
  </div>
  <div class="tbl-container">
    <div class="sbar"><input type="text" id="searchRes" placeholder="بحث في النجوم…" oninput="filterTable('res')"></div>
    <div class="count-bar">
      <span id="countRes">—</span>
      <span style="font-size:10px;color:var(--border2)">اضغط العنوان للترتيب</span>
    </div>
    <div class="res-header">
      <span onclick="sortTable('res','n')">اسم النجم ↕</span>
      <span onclick="sortTable('res','dist')" style="text-align:center">المسافة ↕</span>
      <span onclick="sortTable('res','bear')" style="text-align:center">البوصلة° ↕</span>
    </div>
    <div class="res-list" id="tbodyRes">
      <div class="no-data">أدخل البيانات واضغط "احسب" أولاً</div>
    </div>
  </div>
</div>

<!-- ══ PAGE ROTATED ══ -->
<div class="page" id="page-rotated">
  <div class="card" style="flex-shrink:0">
    <div class="card-title">🔃 الإعدادات اليدوية</div>
    <div class="rot-settings">
      <div class="fg"><label>التحجيم</label><input type="number" id="manScale" value="0.09" step="0.001"></div>
      <div class="fg"><label>الإدارة (°)</label><input type="number" id="manRot" value="51" step="0.1"></div>
      <button class="btn" onclick="calcRotated()">احسب</button>
    </div>
  </div>
  <div class="res-tabs">
    <div class="res-tab active" onclick="setRotTab('center',this)">🔃 مركز مدار</div>
    <div class="res-tab" onclick="setRotTab('star',this)">✦ نجم مدار</div>
  </div>
  <div class="tbl-container">
    <div class="sbar"><input type="text" id="searchRot" placeholder="بحث في النجوم…" oninput="filterTable('rot')"></div>
    <div class="count-bar">
      <span id="countRot">—</span>
      <span style="font-size:10px;color:var(--border2)">اضغط العنوان للترتيب</span>
    </div>
    <div class="res-header">
      <span onclick="sortTable('rot','n')">اسم النجم ↕</span>
      <span onclick="sortTable('rot','dist')" style="text-align:center">المسافة ↕</span>
      <span onclick="sortTable('rot','bear')" style="text-align:center">البوصلة° ↕</span>
    </div>
    <div class="res-list" id="tbodyRot">
      <div class="no-data">أدخل الإعدادات واضغط "احسب"</div>
    </div>
  </div>
</div>

